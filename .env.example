# =============================================================================
#                     movie-vector-rag Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Do NOT commit your real .env file to version control
# =============================================================================

# ==================== Weaviate Configuration ====================

# Weaviate Cloud Cluster URL
# Example: https://my-project123.weaviate.network
WEAVIATE_CLUSTER_URL=

# Weaviate API Key (starts with sk-...)
# Required for Weaviate Cloud. Leave empty if using local Weaviate instance.
WEAVIATE_AUTH_CREDENTIAL=


# ==================== OpenAI Configuration ====================

# OpenAI API Key for generating embeddings
OPENAI_API_KEY=


# ==================== Optional Configuration ====================

# Collection names in Weaviate (you can change these if needed)
MOVIES_COLLECTION=Movie
SYNOPSIS_COLLECTION=Synopsis
REVIEWS_COLLECTION=Review

# Application Environment
ENVIRONMENT=development

# Optional: Limit for seeding data during development
SEED_LIMIT=50